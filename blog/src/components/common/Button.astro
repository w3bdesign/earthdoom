---
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'button'> {
  variant?: "primary" | "secondary" | "ghost";
  size?: "sm" | "md" | "lg" | "xl";
}

const { 
  variant = "primary", 
  size = "md", 
  class: className = "",
  ...props 
} = Astro.props;

const sizeClasses = {
  sm: "px-4 py-2 text-sm min-w-[100px]",
  md: "px-6 py-2.5 text-base min-w-[140px]",
  lg: "px-8 py-3 text-base min-w-[180px]",
  xl: "px-10 py-4 text-lg min-w-[240px]",
};

const variantClasses = {
  primary: `
    bg-gradient-to-r from-blue-600 to-blue-800
    text-white font-semibold
    hover:bg-blue-700
    focus:outline-none focus:ring-2 focus:ring-blue-400 focus:ring-opacity-50
  `,
  secondary: `
    bg-transparent border-2 border-white/60
    hover:bg-white/10 hover:border-white
    text-white font-medium
    shadow-lg hover:shadow-xl hover:shadow-white/20
    focus:ring-4 focus:ring-white/30
    backdrop-blur-sm
  `,
  ghost: `
    bg-transparent
    hover:bg-white/5
    text-white/80 hover:text-white
    font-medium
    focus:ring-2 focus:ring-white/20
  `,
};
---

<button
  class={`
    relative overflow-hidden
    rounded-md
    transition-all duration-500
    group
    ${sizeClasses[size]}
    ${variantClasses[variant]}
    ${className}
  `}
  {...props}
>
  <span class="relative z-10">
    <slot />
  </span>
  {variant === "primary" && (
    <>
      <span
        class="absolute inset-0 bg-gradient-to-r from-blue-400 to-blue-500 opacity-0 transition-opacity duration-300 blur-[2px]"
      ></span>
      <span
        class="absolute top-0 left-0 w-full h-1 bg-blue-400 transform origin-left scale-x-0 transition-transform duration-300 group-hover:scale-x-100 blur-[2px]"
      ></span>
      <span
        class="absolute bottom-0 right-0 w-full h-1 bg-blue-400 transform origin-right scale-x-0 transition-transform duration-300 group-hover:scale-x-100 blur-[2px]"
      ></span>
    </>
  )}
</button>
