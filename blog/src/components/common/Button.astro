---
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'button'> {
  variant?: "primary" | "secondary" | "ghost";
  size?: "sm" | "md" | "lg" | "xl";
}

const {
  variant = "primary",
  size = "md",
  class: className = "",
  ...props
} = Astro.props;

const sizeClasses = {
  sm: "px-4 py-2 text-sm min-w-[100px]",
  md: "px-6 py-2.5 text-base min-w-[140px]",
  lg: "px-8 py-3 text-base min-w-[180px]",
  xl: "px-10 py-4 text-lg min-w-[240px]",
};

const variantClasses = {
  primary: `
    bg-gradient-to-r from-blue-600 to-blue-800
    hover:from-blue-500 hover:to-blue-700
    text-white font-semibold
    shadow-lg shadow-blue-900/40
    hover:shadow-xl hover:shadow-blue-800/50
    focus:ring-4 focus:ring-blue-500/50
    hover:brightness-110
  `,
  secondary: `
    bg-transparent border-2 border-white/60
    hover:bg-white/10 hover:border-white
    text-white font-medium
    shadow-lg hover:shadow-xl hover:shadow-white/20
    focus:ring-4 focus:ring-white/30
    backdrop-blur-sm
  `,
  ghost: `
    bg-transparent
    hover:bg-white/5
    text-white/80 hover:text-white
    font-medium
    focus:ring-2 focus:ring-white/20
  `,
};
---

<button
  class={`
    relative overflow-hidden
    rounded-lg
    transition-all duration-200 ease-out
    focus:outline-none
    active:brightness-95
    ${sizeClasses[size]}
    ${variantClasses[variant]}
    ${className}
  `}
  {...props}
>
  <span class="relative z-10">
    <slot />
  </span>
</button>
